.gradle/
build/
local.properties
.backup/
*.iml
.idea/
*.aapt2.real
*.aapt2.wrapper
*.keystore
keystore.properties
.DS_Store
*.log
*.bak
*.swp
*.swo
# 例外：项目自带的 release keystore 提交到 git，
# 让本地和 CI 用同一份签名，保证覆盖安装不会因签名不同而失败
!app/release-keystore.jks
# 构建时下载的内置资源（不应提交到 Git）
# 但 proot tarball 已 commit（约 228 KB，包含 proot 二进制 + loader + 依赖库）
app/src/main/assets/bundled/*
!app/src/main/assets/bundled/proot-aarch64.tar.gz
!app/src/main/assets/bundled/proot-armhf.tar.gz
